local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local requestFunc = syn and syn.request or http and http.request or request

if not requestFunc then
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "❌ Executor Error",
        Text = "Aapka executor request function support nahi karta.",
        Duration = 5
    })
    return
end

-- Setup Target Part
local testPart = Instance.new("Part")
testPart.Size = Vector3.new(8, 8, 1)
testPart.Position = localPlayer.Character and localPlayer.Character:GetPivot().Position + Vector3.new(0, 5, -15) or Vector3.new(0, 10, -15)
testPart.Anchored = true
testPart.Material = Enum.Material.SmoothPlastic
testPart.Parent = workspace

-- Free Cat API (No Key Required!)
local url = "https://api.thecatapi.com/v1/images/search"

game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "🔄 Fetching...",
    Text = "Cat API se test image laa rahe hain...",
    Duration = 3
})

local response = requestFunc({
    Url = url,
    Method = "GET",
    Headers = {
        ["User-Agent"] = "Mozilla/5.0",
        ["Accept"] = "application/json"
    }
})

if response and response.StatusCode == 200 then
    local success, data = pcall(function()
        return HttpService:JSONDecode(response.Body)
    end)
    
    if success and data and data[1] then
        local catImageUrl = data[1].url
        print("Success URL: ", catImageUrl)
        
        -- Decal Apply
        local decal = Instance.new("Decal")
        decal.Name = "DeltaCatDecal"
        decal.Face = Enum.NormalId.Front
        decal.Texture = catImageUrl
        decal.Parent = testPart
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "✅ Working!",
            Text = "Bina API Key ke image load ho gayi!",
            Duration = 5
        })
    else
        warn("JSON parsing fail hui.")
    end
else
    print("Failed Code: ", response and response.StatusCode or "No Response")
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "❌ Connection Fail",
        Text = "Status Code: " .. tostring(response and response.StatusCode or "Unknown"),
        Duration = 5
    })
end
